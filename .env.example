# === Panel ===
PANEL_DOMAIN=panel.example.com
PANEL_HOST=127.0.0.1
PANEL_PORT=8000
PANEL_JWT_SECRET=
PANEL_JWT_ACCESS_TTL=15m
PANEL_JWT_REFRESH_TTL=720h
PANEL_LOG_LEVEL=info
PANEL_ROOT_DIR=/opt/mypanel
PANEL_FRONTEND_DIR=/opt/mypanel/frontend
PANEL_TEMPLATES_DIR=/opt/mypanel/templates
PANEL_DISABLE_SYSTEMCTL=false

# === Database ===
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=mypanel
DB_USER=panel
DB_PASSWORD=
DB_SSLMODE=disable

# === Xray / VLESS Reality ===
# VLESS_PORT must be reachable from clients; keep it separate from Caddy's
# 80/443 because the panel uses Caddy for HTTPS by default. REALITY_DEST must be
# a TLS1.3 + HTTP/2 host; its name must match REALITY_SNI. REALITY_PRIVATE_KEY /
# REALITY_PUBLIC_KEY are generated by the installer via `xray x25519`.
# REALITY_SHORT_IDS accepts CSV; the empty string "" is a valid shortId that
# allows clients without a sid.
XRAY_BINARY=/usr/local/bin/xray
XRAY_API_ADDR=127.0.0.1:10085
XRAY_CONFIG_PATH=/opt/mypanel/configs/xray/config.json
XRAY_INBOUND_TAG=vless-reality

VLESS_PORT=8444
REALITY_DEST=www.cloudflare.com:443
REALITY_SNI=www.cloudflare.com
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
REALITY_SHORT_IDS=,a1b2c3d4e5f60718

# === Hysteria 2 ===
# HY2_PORT is UDP. HY2_CERT_PATH / HY2_KEY_PATH must exist and be readable by
# the hysteria service user before hysteria.service can start; the installer
# tries to grant group access to /etc/letsencrypt if it finds them there.
# HY2_BANDWIDTH_* accept units: bps|kbps|mbps|gbps|tbps (space-separated ok).
# HY2_MASQUERADE_URL is what plain-browser probes to port HY2_PORT get proxied
# to, disguising the endpoint as an ordinary HTTPS site.
HY2_BINARY=/usr/local/bin/hysteria
HY2_CONFIG_PATH=/opt/mypanel/configs/hysteria/config.json
HY2_TRAFFIC_URL=http://127.0.0.1:7653
HY2_TRAFFIC_SECRET=

HY2_DOMAIN=panel.example.com
HY2_PORT=8443
HY2_OBFS_ENABLED=true
HY2_OBFS_PASSWORD=
HY2_BANDWIDTH_UP=1 gbps
HY2_BANDWIDTH_DOWN=1 gbps
HY2_MASQUERADE_URL=https://www.bing.com
HY2_CERT_PATH=/etc/letsencrypt/live/panel.example.com/fullchain.pem
HY2_KEY_PATH=/etc/letsencrypt/live/panel.example.com/privkey.pem

# === Subscription ===
SUB_URL_PREFIX=https://panel.example.com
SUB_UPDATE_INTERVAL_HOURS=24

# === Backup ===
BACKUP_DIR=/opt/mypanel/data/backups
BACKUP_RETENTION_DAYS=14
BACKUP_TIME_UTC=03:00
